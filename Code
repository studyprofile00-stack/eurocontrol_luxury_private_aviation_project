TARGET_SCHEMA = pa.schema([
    ("id",                  pa.uint64()),
    ("icao24",              pa.string()),
    ("flt_id",              pa.string()),
    ("dof",                 pa.string()),
    ("adep",                pa.string()),
    ("ades",                pa.string()),
    ("registration",        pa.string()),
    ("model",               pa.string()),
    ("typecode",            pa.string()),
    ("icao_aircraft_class", pa.string()),
    ("icao_operator",       pa.string()),
])

TEMP_FOLDER  = "./data/flight_list_temp"
OUTPUT_PATH  = "/content/drive/MyDrive/MSc IBS/Capstone Project/all_eurocontrol_arrivals_2022_2025.parquet"


def generate_urls(start_date: str, end_date: str) -> list:
    base_url = "https://www.eurocontrol.int/performance/data/download/OPDI/v002/flight_list/flight_list_"
    urls = []
    start_dt = datetime.strptime(start_date, "%Y%m")
    end_dt   = datetime.strptime(end_date,   "%Y%m")
    current  = start_dt
    while current <= end_dt:
        urls.append(f"{base_url}{current.strftime('%Y%m')}.parquet")
        current += relativedelta(months=1)
    return urls

def download_and_process(url: str, temp_folder: str) -> str | None:
    file_name = url.split("/")[-1]
    raw_path  = os.path.join(temp_folder, f"raw_{file_name}")
    proc_path = os.path.join(temp_folder, f"proc_{file_name}")

    if os.path.exists(proc_path):
        return proc_path

    try:
        response = requests.get(url, stream=True, timeout=30)
        response.raise_for_status()
        with open(raw_path, "wb") as f:
            for chunk in response.iter_content(chunk_size=1024 * 128):
                f.write(chunk)

        df = pd.read_parquet(raw_path, columns=COLUMNS_TO_KEEP)

        # Important Filter to ensure that my data has only those that landed in eurocontrol zone: Only successful arrivals
        df = df[df["ades"].notna()]

        df.to_parquet(proc_path, index=False, engine="pyarrow", compression="snappy")
        os.remove(raw_path)
        return proc_path

    except Exception as e:
        if os.path.exists(raw_path): os.remove(raw_path)
        print(f"\n  ✗ Error processing {file_name}: {e}")
        return None

def combine_files(processed_paths: list, output_path: str):
    print(f"\nMerging {len(processed_paths)} months into final Master File...")
    writer = None
    total_rows = 0

    with tqdm(total=len(processed_paths), desc="Merging", unit="mo") as pbar:
        for path in processed_paths:
            try:
                table = pq.read_table(path)
                table = table.cast(TARGET_SCHEMA)

                if writer is None:
                    writer = pq.ParquetWriter(output_path, TARGET_SCHEMA, compression="snappy")

                writer.write_table(table)
                total_rows += table.num_rows
                pbar.update(1)
            except Exception as e:
                print(f"\n  ✗ Merge failed for {path}: {e}")

    if writer:
        writer.close()
        size_gb = os.path.getsize(output_path) / (1024 ** 3)
        print(f"\n SUCCESS: {output_path}")
        print(f"   Rows: {total_rows:,} | Size: {size_gb:.2f} GB")

def main():
    os.makedirs(TEMP_FOLDER, exist_ok=True)
    os.makedirs(os.path.dirname(OUTPUT_PATH), exist_ok=True)

    urls = generate_urls("202201", "202512")

    processed_paths = []
    print(f" Starting Pipeline: {len(urls)} Months")

    # progress bar
    for url in tqdm(urls, desc="Downloading/Filtering", unit="file"):
        path = download_and_process(url, TEMP_FOLDER)
        if path:
            processed_paths.append(path)

    if processed_paths:
        combine_files(processed_paths, OUTPUT_PATH)
    else:
        print("No data was successfully processed.")

if __name__ == "__main__":
    main()

